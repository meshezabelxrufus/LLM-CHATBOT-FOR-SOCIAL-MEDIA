# ─────────────────────────────────────────────────────────────────────────────
# Kinderuniversiteit AI Assistant — environment configuration
#
# Copy this file to .env and fill in every value marked <REQUIRED>.
# Values marked [optional] have safe defaults and can be left commented out.
#
# Generate a secret key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

# Deployment environment.  Controls production safety checks, docs visibility,
# CORS policy, and log renderer (json in production, coloured text elsewhere).
# Allowed: development | staging | production
APP_ENV=development

APP_NAME=kinderuniversiteit-ai
APP_VERSION=1.0.0
APP_PORT=8000

# Must be >= 32 random characters in production.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<REQUIRED>


# ── Logging ───────────────────────────────────────────────────────────────────

# Minimum log level.  Allowed: DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_LOG_LEVEL=INFO

# Output renderer.  json = machine-readable (always forced in production).
# text = human-readable coloured console (development default).
# Allowed: json | text
LOG_FORMAT=text

# Leave empty to log to stdout only.  Set a file path to also write to a
# rotating log file (e.g. /var/log/kinderuniversiteit/app.log).
LOG_FILE_PATH=

# RotatingFileHandler settings — only used when LOG_FILE_PATH is set.
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5


# ── Paths ─────────────────────────────────────────────────────────────────────

# Directory containing system_prompt.md and the prompt_manager.py module.
# Relative paths are resolved from the working directory at startup.
PROMPTS_DIR=app/prompts

# Jinja2 template directory (inside PROMPTS_DIR).
TEMPLATES_DIR=app/prompts/templates

# Directory where uploaded PDF knowledge-base files are stored.
# Created automatically at startup if it does not exist.
KNOWLEDGE_DIR=data/knowledge

# Persistent storage directory for embedded ChromaDB.
# Only used when CHROMA_HOST is left empty (embedded mode).
# Created automatically at startup if it does not exist.
CHROMA_PERSIST_DIR=data/chroma


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────

# Async SQLAlchemy DSN.  Must use the asyncpg driver.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kinderuniversiteit

# Connection pool tuning.  Increase for high-traffic deployments.
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Set True only for local debugging — logs every SQL statement.
# Never enable in production.
DATABASE_ECHO=false


# ── OpenAI ────────────────────────────────────────────────────────────────────

# Your OpenAI API key.  Must start with sk- or sk-proj-.
OPENAI_API_KEY=<REQUIRED>

# Chat completion model.
OPENAI_MODEL=gpt-4o

# Embedding model used for RAG vector search.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Maximum tokens per completion response.  Must be 1-32768.
OPENAI_MAX_TOKENS=1024

# Sampling temperature.  0.0 = deterministic, 2.0 = very random.
# 0.3 gives consistent, focused customer-service answers.
OPENAI_TEMPERATURE=0.3

# Per-request HTTP timeout in seconds.
OPENAI_TIMEOUT=30.0


# ── ChromaDB ─────────────────────────────────────────────────────────────────

# Remote mode   -> set CHROMA_HOST to the hostname/IP of your ChromaDB server.
# Embedded mode -> leave CHROMA_HOST empty; ChromaDB runs in-process using
#                  CHROMA_PERSIST_DIR as its storage root.
CHROMA_HOST=
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=kinderuniversiteit_kb


# ── ManyChat ─────────────────────────────────────────────────────────────────

# ManyChat API token (Bearer auth for outbound API calls).  Required in production.
MANYCHAT_API_KEY=<REQUIRED>

# HMAC-SHA256 secret for verifying incoming webhook signatures.
# Required in production.  Set the same value in your ManyChat flow settings.
MANYCHAT_WEBHOOK_SECRET=<REQUIRED>

MANYCHAT_BASE_URL=https://api.manychat.com


# ── Redis ─────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0

# Default TTL for cached values in seconds.
CACHE_TTL_SECONDS=300


# ── Rate limiting ─────────────────────────────────────────────────────────────

# Maximum inbound messages per contact per 60-second sliding window.
RATE_LIMIT_MESSAGES_PER_MINUTE=20


# ── Escalation ───────────────────────────────────────────────────────────────

# Email address that receives escalation notifications.  [optional]
ESCALATION_EMAIL=

# AI confidence score below which a message is automatically escalated.
# 0.0 = never escalate on confidence, 1.0 = always escalate.
ESCALATION_CONFIDENCE_THRESHOLD=0.6

# Optional webhook URL for escalation notifications (Slack / Teams / custom).
ESCALATION_WEBHOOK_URL=


# ── Analytics ─────────────────────────────────────────────────────────────────

ANALYTICS_ENABLED=true


# ── CRM integration (future) ──────────────────────────────────────────────────

CRM_API_KEY=
CRM_BASE_URL=
